{
	"compilerOptions": {
		"rootDir": "./",
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
		"target": "es2023",
		"module": "esnext",
		"types": ["vite/client", "chrome"],
		"noEmit": true,
		"allowJs": true,
		"checkJs": true,
		"moduleDetection": "force",
		"declaration": true,
		"jsx": "react-jsx"
	},
	"include": [
		"src",
		"tests",
		"vite.config.ts",
		"vite.config.test.ts",
		"eslint.config.ts",
		"playwright.config.ts"
	],
	"exclude": ["dist", "tests/dist"]
}
