{
	"manifest_version": 3,
	"name": "annot-test",
	"version": "0.0.1",
	"description": "Annotation library testing",
	"browser_specific_settings": {
		"gecko": {
			"id": "annot@test.com",
			"data_collection_permissions": {
				"required": ["none"]
			}
		}
	},
	"action": {
		"default_title": "annot-test",
		"default_popup": "index.html"
	},
	"background": {
		"scripts": ["background-script.js"],
		"service_worker": "background-script.js",
		"type": "module"
	},
	"permissions": ["storage"],
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["content-script-entry.js"],
			"css": ["content-script.css"]
		}
	],
	"web_accessible_resources": [
		{
			"resources": ["*"],
			"matches": ["<all_urls>"]
		}
	]
}
