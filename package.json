{
	"name": "anno-webext",
	"version": "0.0.1",
	"description": "Annotation library for web extension",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/dqkqd/anno-webext.git"
	},
	"author": "Khanh Duong",
	"license": "MIT",
	"keywords": [
		"annotations",
		"highlights",
		"web-extension",
		"webext",
		"chrome-extension",
		"browser-extension",
		"addon"
	],
	"type": "module",
	"scripts": {
		"build": "vite build",
		"build:debug": "vite build --minify=false --sourcemap=inline",
		"build:test": "npm run build && vite build -c vite.config.test.ts",
		"build:test:debug": "npm run build:debug && vite build -c vite.config.test.ts --minify=false --sourcemap=inline",
		"lint": "npm run build && eslint .",
		"lint:fix": "eslint --fix .",
		"format": "biome check --write --linter-enabled=false",
		"format:check": "biome check --linter-enabled=false",
		"test": "npm run build:test && playwright test",
		"test:debug": "npm run build:test:debug && playwright test --ui --headed",
		"web-ext:firefox": "npm run build:test:debug && web-ext run --source-dir ./tests/dist --start-url https://en.wikipedia.org/wiki/Alan_Turing",
		"web-ext:chrome": "npm run web-ext:firefox -- --target chromium"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/anno-webext.js"
		}
	},
	"files": ["./dist/index.d.ts", "./dist/anno-webext.js"],
	"engines": {
		"node": ">= 26",
		"npm": ">= 11"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@eslint/css": "^1.3.0",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "1.60.0",
		"@types/chrome": "^0.1.43",
		"@types/node": "^24.12.3",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"esbuild": "^0.28.1",
		"eslint": "^10.5.0",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-unicorn": "^69.0.0",
		"globals": "^17.7.0",
		"jiti": "^2.7.0",
		"playwright-webextext": "^0.0.5",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"tslib": "^2.8.1",
		"typescript": "~6.0.2",
		"typescript-eslint": "^8.62.0",
		"unplugin-dts": "^1.0.3",
		"vite": "^8.0.12",
		"web-ext": "^0.0.1"
	}
}
