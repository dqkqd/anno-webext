{
  "name": "anno-webext",
  "version": "0.0.6",
  "description": "Annotation library for web extension",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dqkqd/anno-webext.git"
  },
  "author": "Khanh Duong",
  "license": "MIT",
  "keywords": [
    "annotations",
    "highlights",
    "web-extension",
    "webext",
    "chrome-extension",
    "browser-extension",
    "addon"
  ],
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:debug": "vite build --minify=false --sourcemap=inline",
    "build:e2e": "npm run build && vite build -c vite.config.e2e.ts",
    "build:e2e:debug": "npm run build:debug && vite build -c vite.config.e2e.ts --minify=false --sourcemap=inline",
    "lint": "npm run build && eslint .",
    "lint:fix": "eslint --fix .",
    "test:unit": "vitest run",
    "test": "npm run test:unit && npm run test:e2e",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "test:e2e": "npm run build:e2e && playwright test",
    "test:e2e:debug": "npm run build:e2e:debug && playwright test --ui --headed",
    "web-ext:firefox": "npm run build:e2e:debug && web-ext run --source-dir ./tests/dist --start-url https://en.wikipedia.org/wiki/Alan_Turing",
    "web-ext:chrome": "npm run web-ext:firefox -- --target chromium"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/anno-webext.js"
    }
  },
  "files": [
    "./dist/anno-webext.js",
    "./dist/index.d.ts"
  ],
  "engines": {
    "node": ">= 26",
    "npm": ">= 11"
  },
  "devDependencies": {
    "@eslint/css": "^1.3.0",
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.58.11",
    "@playwright/test": "1.61.1",
    "@types/chrome": "^0.1.43",
    "@types/node": "^24.12.3",
    "@types/rbush": "^4.0.0",
    "dprint": "^0.55.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-plugin-unicorn": "^72.0.0",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "playwright-webextext": "^0.0.5",
    "tslib": "^2.8.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "unplugin-dts": "^1.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.10",
    "web-ext": "^10.5.0"
  },
  "dependencies": {
    "rbush": "^4.0.1"
  }
}
